# 鼎伟 CRM 业务人员端 - 后端环境变量样板
#
# 用法:
#   cp .env.example .env          # 拷一份本机配置
#   vim .env                      # 改密码 / DEEPSEEK_API_KEY 等
#
# docker-compose 里通过 services.backend.environment 已经注入这些,
# 本文件主要给 Mac 本机直跑(`uvicorn app.main:app --reload`)用。

# ─── 运行环境 ─────────────────────────────────────────────────
ENV=dev
DEBUG=false

# ─── 数据库 ──────────────────────────────────────────────────
# Mac 本机直跑(需 brew install msodbcsql18 mssql-tools18):
#   DATABASE_URL=mssql+aioodbc://sa:Dingwei!Strong#2026@localhost:1433/dingwei_crm_sales?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
#
# docker 内运行:
#   DATABASE_URL=mssql+aioodbc://sa:Dingwei!Strong#2026@sqlserver:1433/dingwei_crm_sales?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
DATABASE_URL=mssql+aioodbc://sa:Dingwei!Strong#2026@localhost:1433/dingwei_crm_sales?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# 调试模式打印 SQL
DB_ECHO=false

# ─── 鉴权 ───────────────────────────────────────────────────
# 生产前必须替换为随机 64 字符以上
JWT_SECRET=change_me_in_prod_or_will_be_breached
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── AI(Phase 1B 启用) ──────────────────────────────────────
DEEPSEEK_API_KEY=change_me

# ─── 缓存(infra 留位,1A 不使用) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── 照片上传(Q7 决议) ─────────────────────────────────────
UPLOAD_DIR=./uploads
# 5MB
UPLOAD_MAX_SIZE_BYTES=5242880
# O3 悬挂:per-user 限速(初值,Phase 1A 实施时再调)
UPLOAD_RATE_LIMIT_PER_HOUR=30
UPLOAD_RATE_LIMIT_PER_DAY=100

# ─── CORS ─────────────────────────────────────────────────
# 用逗号分隔多个 origin
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080
